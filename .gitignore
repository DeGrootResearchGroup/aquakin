# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
wheels/
*.egg
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage artefacts
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type-checker / linter caches
.mypy_cache/
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo

# Operating system
.DS_Store
Thumbs.db

# Project-local settings (worktrees, local settings) -- but track the
# path-scoped guidance rules, which must ship with the repo to load.
.claude/*
!.claude/rules/
reference/
figures/
